# General Settings
PROJECT_NAME="SCRB AI Crime Intelligence Platform"
ENVIRONMENT="development"
DEBUG=true
API_V1_STR="/api/v1"

# Database Configuration
# For local SQLite development: sqlite:///./crime_intelligence.db
# For PostgreSQL: postgresql://username:password@localhost:5432/dbname
DATABASE_URL="sqlite:///./crime_intelligence.db"

# JWT Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="your-super-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Zoho Catalyst Config (if using local mocking or direct APIs)
ZOHO_CATALYST_PROJECT_ID="your-project-id"
ZOHO_CATALYST_CLIENT_ID="your-client-id"
ZOHO_CATALYST_CLIENT_SECRET="your-client-secret"

# Report Generation
REPORT_STORAGE_PROVIDER="catalyst"
REPORTS_LOCAL_DIR="storage/reports"
